# =============================================================================
# Local OTEL Stack — Environment Variables
# Copy to .env and edit as needed.
# =============================================================================

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin
GRAFANA_VERSION=10.4.3

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_RETENTION=30d
PROMETHEUS_VERSION=v2.51.2

# ── OTEL Collector ────────────────────────────────────────────────────────────
OTEL_COLLECTOR_VERSION=0.96.0

# ── Tempo / Loki ──────────────────────────────────────────────────────────────
TEMPO_VERSION=2.4.1
LOKI_VERSION=2.9.4

# ── Opik (only needed with docker-compose.opik.yml) ──────────────────────────
OPIK_BACKEND_VERSION=0.9.0
OPIK_FRONTEND_VERSION=0.9.0
OPIK_MYSQL_PASSWORD=opik_secret
OPIK_MYSQL_ROOT_PASSWORD=root_secret
OPIK_CLICKHOUSE_PASSWORD=opik_secret
OPIK_MYSQL_VERSION=8.0.36
OPIK_CLICKHOUSE_VERSION=24.3-alpine
OPIK_REDIS_VERSION=7.2-alpine
