# =============================================================================
# Local OTEL Stack — Environment Variables
# Copy to .env and edit as needed.
# =============================================================================

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=admin

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_RETENTION=30d

# ── Opik (only needed with docker-compose.opik.yml) ──────────────────────────
OPIK_MYSQL_PASSWORD=opik_secret
OPIK_MYSQL_ROOT_PASSWORD=root_secret
OPIK_CLICKHOUSE_PASSWORD=opik_secret
