# =============================================================================
# Generic Python Service — OTEL environment variables
# Works with opentelemetry-sdk + opentelemetry-exporter-otlp-proto-http
# =============================================================================

OTEL_SERVICE_NAME=my-service
OTEL_SERVICE_VERSION=1.0.0
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_TRACES_SAMPLER=parentbased_always_on

# Resource attributes (appear as labels in Grafana)
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local,team=backend
