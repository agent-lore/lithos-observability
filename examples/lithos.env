# =============================================================================
# Lithos — OTEL environment variables
# Add these to your lithos docker-compose service environment section,
# or export them before running lithos locally.
#
# Assumes the local-otel-stack is running and reachable at localhost.
# When running lithos in Docker on the same host, use host.docker.internal
# instead of localhost (already configured via extra_hosts in lithos compose).
# =============================================================================

# Enable OTEL instrumentation in Lithos
LITHOS_OTEL_ENABLED=true

# OTEL service identity
OTEL_SERVICE_NAME=lithos
OTEL_SERVICE_VERSION=0.1.2

# Point to the OTEL Collector HTTP endpoint
# Docker-to-Docker (same compose network):  http://otel-collector:4318
# Docker-to-host stack:                     http://host.docker.internal:4318
# Local dev (no Docker):                    http://localhost:4318
OTEL_EXPORTER_OTLP_ENDPOINT=http://host.docker.internal:4318

# What to export (all three for full observability)
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp

# Sampling — 1.0 = 100% of traces (fine for low-volume local use)
OTEL_TRACES_SAMPLER=parentbased_always_on

# Optional: enable LLM tracing via OpenLIT (Phase 3)
# LITHOS_LLM_TRACING=true
